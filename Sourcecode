async function analyzeMessage() {
  const text = document.getElementById('msg-input').value.trim();
  if (!text && !imageUploaded) return;

  document.getElementById('analyze-btn').disabled = true;
  document.getElementById('loading-section').classList.remove('hidden');
  document.getElementById('results-section').classList.add('hidden');
  lucide.createIcons();

  const steps = ["Scanning for scam patterns", "Checking for urgency manipulation", "Analyzing financial fraud signals", "Evaluating suspicious links", "Generating safety report"];
  for (let i = 0; i < steps.length; i++) {
    await new Promise(r => setTimeout(r, 600));
    document.getElementById('loading-step').textContent = steps[i];
  }

  // Determine which analysis to use
  let result;
  const matchIdx = examples.findIndex(ex => text === ex);
  if (matchIdx >= 0) {
    result = analyses[matchIdx];
  } else if (imageUploaded && !text) {
    result = { score: 75, level: "High", color: "#f97316", title: "Suspicious Image Detected", summary: "The uploaded screenshot contains elements commonly associated with scam messages.", indicators: ["Image contains text patterns matching known scam formats", "Visual layout mimics legitimate service notifications", "Contains urgency cues and financial references"], recommendations: ["Do not act on information in this screenshot", "Verify with the official service provider directly", "Report to local cybercrime authorities", "Warn others who may receive similar images"] };
  } else {
    result = generateAnalysis(text);
  }

  await new Promise(r => setTimeout(r, 400));
  document.getElementById('loading-section').classList.add('hidden');
  showResults(result);
}

function showResults(r) {
  const section = document.getElementById('results-section');
  section.classList.remove('hidden');

  // Animate score
  const circle = document.getElementById('score-circle');
  const offset = 327 - (327 * r.score / 100);
  circle.style.stroke = r.color;
  circle.style.transition = 'stroke-dashoffset 1s ease';
  setTimeout(() => circle.style.strokeDashoffset = offset, 50);

  let counter = 0;
  const numEl = document.getElementById('score-num');
  const interval = setInterval(() => {
    counter += Math.ceil(r.score / 30);
    if (counter >= r.score) { counter = r.score; clearInterval(interval); }
    numEl.textContent = counter;
    numEl.style.color = r.color;
  }, 30);

  document.getElementById('risk-badge').textContent = r.level + ' Risk';
  document.getElementById('risk-badge').style.cssText = `background:${r.color}20;color:${r.color};`;
  document.getElementById('risk-title').textContent = r.title;
  document.getElementById('risk-summary').textContent = r.summary;

  const indList = document.getElementById('indicators-list');
  indList.innerHTML = r.indicators.map((ind, i) => `
    <div class="flex items-start gap-3 anim-slide" style="animation-delay:${i*0.1}s">
      <div class="w-6 h-6 rounded-full bg-amber-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
        <i data-lucide="alert-circle" style="width:14px;height:14px;color:#fbbf24"></i>
      </div>
      <span class="text-sm text-slate-300">${ind}</span>
    </div>
  `).join('');

  const recList = document.getElementById('recommendations-list');
  recList.innerHTML = r.recommendations.map((rec, i) => `
    <div class="flex items-start gap-3 anim-slide" style="animation-delay:${i*0.1+0.2}s">
      <div class="w-6 h-6 rounded-full bg-emerald-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
        <i data-lucide="check-circle" style="width:14px;height:14px;color:#34d399"></i>
      </div>
      <span class="text-sm text-slate-300">${rec}</span>
    </div>
  `).join('');

  document.getElementById('analyze-btn').disabled = false;
  lucide.createIcons();
}

