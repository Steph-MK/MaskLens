// Generic analysis for custom input
function generateAnalysis(text) {
  const t = text.toLowerCase();
  let score = 40, indicators = [], recommendations = [];
  
  if (/pin|password|account.*(detail|number)|bank/i.test(t)) { score += 25; indicators.push("Requests sensitive personal/financial information"); }
  if (/urgent|immediate|expire|hour|minute|hurry|quick|fast|now/i.test(t)) { score += 15; indicators.push("Uses urgency and pressure tactics"); }
  if (/won|congratulat|selected|lucky|winner/i.test(t)) { score += 15; indicators.push("Claims unexpected winnings or selection"); }
  if (/\$\d|₦\d|ghs\s?\d|usd\s?\d/i.test(t)) { score += 10; indicators.push("Mentions specific monetary amounts as bait"); }
  if (/click|link|bit\.ly|http|www\./i.test(t)) { score += 10; indicators.push("Contains suspicious links"); }
  if (/fee|pay|send.*money|registration|process/i.test(t)) { score += 20; indicators.push("Requires upfront payment or fees"); }
  if (/whatsapp|telegram|dm|inbox/i.test(t)) { score += 5; indicators.push("Directs to informal messaging channels"); }
  if (/no experience|easy money|work from home|earn.*day/i.test(t)) { score += 15; indicators.push("Makes unrealistic income promises"); }

  if (indicators.length === 0) indicators.push("No strong scam indicators detected, but always stay cautious");
  
  score = Math.min(score, 98);
  recommendations = ["Do not respond to or forward this message","Never share personal or financial information","Verify claims through official channels only","Report suspicious messages to local authorities"];

  const level = score >= 80 ? "Critical" : score >= 60 ? "High" : score >= 40 ? "Medium" : "Low";
  const color = score >= 80 ? "#ef4444" : score >= 60 ? "#f97316" : score >= 40 ? "#eab308" : "#22c55e";
  const title = score >= 70 ? "Likely Scam Detected" : score >= 40 ? "Suspicious Content" : "Low Risk Message";
  const summary = score >= 70 ? "This message contains multiple scam indicators commonly seen in fraud targeting Africans." : score >= 40 ? "Some suspicious elements were detected. Exercise caution." : "This message appears relatively safe, but always verify independently.";

  return { score, level, color, title, summary, indicators, recommendations };
}

